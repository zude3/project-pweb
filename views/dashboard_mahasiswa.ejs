<%- include('partials/header') %>

<style>
    .dashboard-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .btn { padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 500; text-decoration: none; display: inline-block; margin-left: 10px; }
    .btn-danger { background-color: #e74c3c; color: white; }
    .btn-danger:hover { background-color: #c0392b; }
    .card { background: white; border-radius: 8px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 20px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
    th { background-color: #2c3e50; color: white; }
    .badge { padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }
    .badge-mhs { background: #d6eaf8; color: #1a5276; }
    .badge-dipinjam { background: #fdebd0; color: #784212; }
    .badge-dikembalikan { background: #d5f5e3; color: #1e8449; }
</style>

<div style="max-width: 1000px; margin: 0 auto;">
    <div class="dashboard-header">
        <div>
            <h1>Dashboard Mahasiswa</h1>
            <p>Selamat datang, <strong><%= currentUser.name %></strong>
               <span class="badge badge-mhs"><%= currentUser.role %></span>
            </p>
        </div>
        <a href="/logout" class="btn btn-danger">Logout</a>
    </div>

    <div class="card">
        <h2>Peralatan Tersedia</h2>
        <% if (typeof peralatan !== 'undefined' && peralatan.length > 0) { %>
        <table>
            <thead>
                <tr><th>No</th><th>Nama Alat</th><th>Tersedia</th><th>Aksi</th></tr>
            </thead>
            <tbody>
                <% peralatan.forEach((alat, i) => { %>
                <tr>
                    <td><%= i + 1 %></td>
                    <td><%= alat.nama %></td>
                    <td><%= alat.tersedia %></td>
                    <td>
                        <% if (hasPermission('pinjam-alat') && alat.tersedia > 0) { %>
                            <a href="/pinjam/<%= alat.id %>">Pinjam</a>
                        <% } else if (alat.tersedia === 0) { %>
                            <span style="color:#e74c3c;">Habis</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } else { %>
            <p style="color: #888;">Belum ada peralatan tersedia.</p>
        <% } %>
    </div>

    <div class="card">
        <h2>Riwayat Peminjaman Saya</h2>
        <% if (typeof peminjaman !== 'undefined' && peminjaman.length > 0) { %>
        <table>
            <thead>
                <tr><th>No</th><th>Alat</th><th>Jumlah</th><th>Tgl Pinjam</th><th>Tgl Kembali</th><th>Status</th></tr>
            </thead>
            <tbody>
                <% peminjaman.forEach((p, i) => { %>
                <tr>
                    <td><%= i + 1 %></td>
                    <td><%= p.nama_alat %></td>
                    <td><%= p.jumlah_pinjam %></td>
                    <td><%= p.tanggal_pinjam %></td>
                    <td><%= p.tanggal_kembali || '-' %></td>
                    <td><span class="badge badge-<%= p.status %>"><%= p.status %></span></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } else { %>
            <p style="color: #888;">Belum ada riwayat peminjaman.</p>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>